// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// For production deployment with Neon PostgreSQL:
// 1. Change provider to "postgresql"
// 2. Set DATABASE_URL to your Neon connection string
// 3. Run prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  email     String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String?
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("general")
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  excerpt     String?
  image       String?
  category    String   @default("kegiatan")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  position  String
  subject   String?
  image     String?
  phone     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id        String   @id @default(cuid())
  name      String
  class     String
  nis       String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Achievement {
  id          String   @id @default(cuid())
  title       String
  description String?
  achiever    String
  category    String   @default("santri")
  level       String?
  year        String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Gallery {
  id        String   @id @default(cuid())
  title     String
  image     String
  category  String   @default("kegiatan")
  year      String?
  type      String   @default("foto")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Program {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   @default("unggulan")
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  location    String?
  image       String?
  category    String   @default("kegiatan")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  content   String
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Download {
  id        String   @id @default(cuid())
  title     String
  fileUrl   String
  category  String   @default("formulir")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PPDBRegistration {
  id              String   @id @default(cuid())
  name            String
  birthPlace      String
  birthDate       DateTime
  parentName      String
  parentPhone     String
  address         String?
  previousSchool  String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Alumni {
  id              String   @id @default(cuid())
  name            String
  year            String
  testimony       String?
  image           String?
  currentActivity String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dakwah {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   @default("artikel")
  author      String?
  videoUrl    String?
  image       String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InstitutionData {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String
}

model Schedule {
  id        String   @id @default(cuid())
  title     String
  day       String
  timeStart String
  timeEnd   String
  subject   String?
  teacher   String?
  class     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentInfo {
  id          String   @id @default(cuid())
  title       String
  amount      String
  description String?
  dueDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Suggestion {
  id        String   @id @default(cuid())
  name      String
  email     String?
  type      String   @default("saran")
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Statistic {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String
}
