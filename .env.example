# ============================================
# Environment Variables - MDTA Miftahul Ulum 01
# ============================================

# --- Neon PostgreSQL (REQUIRED FOR VERCEL) ---
# Get your connection string from: https://console.neon.tech
# Use the POOLED connection for DATABASE_URL (for serverless)
# Use the DIRECT connection for DIRECT_URL (for migrations)

DATABASE_URL=postgresql://username:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# --- Cloudinary (image storage) ---
# Get from: https://console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
