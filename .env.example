# ============================================
# Environment Variables - MDTA Miftahul Ulum 01
# ============================================
# Copy this file as .env and fill in your values

# --- Local Development (SQLite) ---
DATABASE_URL=file:./dev.db

# --- Production (Neon PostgreSQL) ---
# Uncomment and fill with your Neon connection string for Vercel deployment
# DATABASE_URL=postgresql://username:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# DIRECT_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# --- NextAuth (optional, for future use) ---
# NEXTAUTH_SECRET=your-secret-key-here
# NEXTAUTH_URL=https://your-domain.vercel.app
